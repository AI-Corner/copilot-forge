# Copilot Forge - GitLab Sync Configuration
# Save this file as .forge/.env.local
# DO NOT COMMIT THIS FILE. It is ignored by default in the .gitignore template.

# Your company's GitLab instance URL (e.g., https://gitlab.com or https://gitlab.internal.corp)
GITLAB_URL="https://gitlab.example.com"

# Personal Access Token (requires 'api' scope to create Epics and Issues)
GITLAB_TOKEN="glpat-xxxxxxxxxxxxxxxxxxxx"

# The Group ID where the Epic (Requirement) will be created. 
# Epics in GitLab are Group-level entities.
GITLAB_GROUP_ID="12345"

# The Project IDs where individual Issues (Tasks) will be created.
# You can define multiple if your architecture spans multiple repositories.
# Copilot will map tasks to these IDs based on the task's target repository.
GITLAB_PROJECT_ID_FRONTEND="101"
GITLAB_PROJECT_ID_BACKEND="102"
GITLAB_PROJECT_ID_INFRA="103"

## Internal Reference
- **Incoming Dependencies**: `#forge-issue-epic-creation`, `#forge-init`
- **Outgoing Dependencies**: *None*
- **Resource Dependencies**: *None*